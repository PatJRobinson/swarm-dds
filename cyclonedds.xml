<CycloneDDS xmlns="https://cdds.io/config">
  <Domain id="any">
    <General>
      <Interfaces>
        <NetworkInterface name="eno1"/>
      </Interfaces>
      <AllowMulticast>true</AllowMulticast>
    </General>
    <Tracing>
      <Verbosity>finest</Verbosity>
      <OutputFile>logs/cdds.log.${CYCLONEDDS_PID}</OutputFile>
    </Tracing>
  </Domain>
</CycloneDDS>
